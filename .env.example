# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# On the NUC: chmod 600 .env

# --- Runtime ---
# Which connector the morning job uses: "mock" (Phase 0, no creds) or "zerodha" (Phase 1+).
PORTFOLIO_CONNECTOR=mock

# Path to the config file (defaults to config.yaml next to the repo root).
PORTFOLIO_CONFIG=config.yaml

# --- Database ---
# Leave unset to use a local SQLite file (data/portfolio.db) — zero setup, good for dev/tests.
# On the NUC, point this at the Dockerized Postgres:
# DATABASE_URL=postgresql+psycopg://portfolio:CHANGE_ME@localhost:5432/portfolio
# DATABASE_URL=

# --- Zerodha / Kite (Phase 1+) ---
# KITE_API_KEY=
# KITE_API_SECRET=
# KITE_USER_ID=
# KITE_PASSWORD=
# KITE_TOTP_SECRET=          # base32 TOTP seed for automated daily login

# --- LLM (Phase 4+) ---
# ANTHROPIC_API_KEY=

# --- Widget API (Phase 3+) ---
# WIDGET_API_TOKEN=          # bearer token the iOS widget presents
